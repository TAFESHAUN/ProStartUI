<Window x:Class="ProStartUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProStartUI"
        xmlns:system="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="Activity Tracker" Height="480" Width="620"
        Background="#F0F0F0">

    <Window.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#AAAAAA"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="#E1E1E1"/>
            <Setter Property="BorderBrush" Value="#AAAAAA"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <TabControl FontSize="13" Background="wheat">

            <!-- TAB 1: Add Activity -->
            <TabItem Header="Add Activity">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Date and Time -->
                    <Grid Grid.Row="0" Margin="0,8,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Date and Time" Style="{StaticResource LabelStyle}"/>
                        <DatePicker Grid.Column="1" Height="26"
                                    x:Name="ActivityDatePicker"
                                    SelectedDate="{x:Static system:DateTime.Now}"/>
                    </Grid>

                    <!-- Title -->
                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Title" Style="{StaticResource LabelStyle}"/>
                        <TextBox Grid.Column="1" Style="{StaticResource FieldBox}"
                                 x:Name="TitleBox"/>
                    </Grid>

                    <!-- Cost -->
                    <Grid Grid.Row="2" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Cost" Style="{StaticResource LabelStyle}"/>
                        <TextBox Grid.Column="1" Style="{StaticResource FieldBox}"
                                 x:Name="CostBox"/>
                    </Grid>

                    <!-- Inner tabs: Fitness / Entertainment -->
                    <TabControl Grid.Row="3" BorderBrush="#AAAAAA" BorderThickness="1">

                        <TabItem Header="Fitness">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Location"
                                           FontSize="13" Margin="0,8,0,6"/>
                                <TextBox Grid.Row="1" Style="{StaticResource FieldBox}"
                                         x:Name="LocationBox" Margin="0,0,0,12"/>
                                <Button Grid.Row="2" Content="Save Fitness Activity"
                                        Style="{StaticResource ActionButton}"/>
                            </Grid>
                        </TabItem>

                        <TabItem Header="Entertainment">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Min Participants"
                                           FontSize="13" Margin="0,8,0,6"/>
                                <TextBox Grid.Row="1" Style="{StaticResource FieldBox}"
                                         x:Name="MinParticipantsBox" Margin="0,0,0,12"/>
                                <Button Grid.Row="2" Content="Save Entertainment Activity"
                                        Style="{StaticResource ActionButton}"/>
                            </Grid>
                        </TabItem>

                    </TabControl>
                </Grid>
            </TabItem>

            <!-- TAB 2: Search Activities -->
            <TabItem Header="Search Activities">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Search Date -->
                    <Grid Grid.Row="0" Margin="0,8,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Search Date" Style="{StaticResource LabelStyle}"/>
                        <DatePicker Grid.Column="1" Height="26"
                                    x:Name="SearchDatePicker"
                                    SelectedDate="{x:Static system:DateTime.Now}"/>
                    </Grid>

                    <!-- Search Criteria -->
                    <Grid Grid.Row="1" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Search Criteria" Style="{StaticResource LabelStyle}"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <RadioButton Content="Before" Margin="0,0,20,0" FontSize="13"
                                         GroupName="Criteria" x:Name="RadioBefore"/>
                            <RadioButton Content="On"     Margin="0,0,20,0" FontSize="13"
                                         GroupName="Criteria" x:Name="RadioOn" IsChecked="True"/>
                            <RadioButton Content="After"  FontSize="13"
                                         GroupName="Criteria" x:Name="RadioAfter"/>
                        </StackPanel>
                    </Grid>

                    <Button Grid.Row="2" Content="Search Activities"
                            Style="{StaticResource ActionButton}"
                            Margin="0,0,0,8"/>

                    <Button Grid.Row="3" Content="Display All Activities"
                            Style="{StaticResource ActionButton}"
                            Margin="0,0,0,12" Click="DisplayAll_Click"/>

                    <DataGrid Grid.Row="4"
                              x:Name="ResultsGrid"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              BorderBrush="#AAAAAA"
                              BorderThickness="1"
                              RowBackground="White"
                              AlternatingRowBackground="#F7F7F7"
                              FontSize="13">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="DateTime"
                                               Binding="{Binding DateStartTime}" Width="180"/>
                            <DataGridTextColumn Header="Title"
                                               Binding="{Binding Title}" Width="*"/>
                            <DataGridTextColumn Header="Cost"
                                               Binding="{Binding Cost}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>

                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>